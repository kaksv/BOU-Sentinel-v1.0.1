# BOU Sentinel Frontend - Production Environment Variables
# After deploying the backend on Render, set these in Vercel project settings:
#
# VITE_API_URL=https://bou-sentinel-api.onrender.com
# VITE_WS_URL=wss://bou-sentinel-api.onrender.com/ws
#
# These will be injected at build time by Vite.

VITE_API_URL=
VITE_WS_URL=